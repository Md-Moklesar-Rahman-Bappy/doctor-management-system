<?php

namespace App\Http\Requests;

use Illuminate\Foundation\Http\FormRequest;
use Illuminate\Contracts\Validation\Validator;
use Illuminate\Http\Exceptions\HttpResponseException;

class StorePrescriptionRequest extends FormRequest
{
    /**
     * Determine if the user is authorized to make this request.
     */
    public function authorize(): bool
    {
        return auth()->check();
    }

    public function rules(): array
    {
        return [
            'patient_id' => 'required_without:new_patient_name|exists:patients,id',
            'doctor_id' => 'required|exists:doctors,id',
            'problem' => 'nullable',
            'tests' => 'nullable',
            'medicines' => 'nullable',
            'new_patient_name' => 'nullable|required_without:patient_id|string|max:255',
            'new_patient_age' => 'nullable|required_with:new_patient_name|integer|min:0|max:150',
            'new_patient_sex' => 'nullable|required_with:new_patient_name|in:male,female',
            'new_patient_date' => 'nullable|required_with:new_patient_name|date',
        ];
    }

    public function messages(): array
    {
        return [
            'patient_id.required_without' => 'Patient is required.',
            'doctor_id.required' => 'Doctor is required.',
            'new_patient_name.required' => 'Patient name is required.',
            'new_patient_age.required' => 'Age is required.',
            'new_patient_sex.required' => 'Sex is required.',
            'new_patient_date.required' => 'Date is required.',
        ];
    }

    protected function failedValidation(Validator $validator)
    {
        \Log::warning('Prescription validation failed', [
            'errors' => $validator->errors()->toArray(),
            'input' => request()->except(['_token'])
        ]);
        
        // Temporary: return a simple error to see if this method is called
        throw new \Exception('Validation failed in StorePrescriptionRequest - this method is being called!');
    }
}
